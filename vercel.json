{
  "version": 2,
  "builds": [
    {
      "src": "wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "wsgi.py"
    },
    {
      "src": "/",
      "dest": "static/FitCoach_Pro.html"
    },
    {
      "src": "/(.*)",
      "dest": "wsgi.py"
    }
  ]
}